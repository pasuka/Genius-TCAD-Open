/* config.h - generated by CMake configure_file() */

#ifndef _CONFIG_H_CMAKE
#define _CONFIG_H_CMAKE

/* Platform */
#cmakedefine LINUX 1
#cmakedefine WINDOWS 1
#cmakedefine WIN32 1
#cmakedefine DARWIN 1
#cmakedefine DLLHOOK 1

/* Type sizes */
#cmakedefine SIZEOF_DOUBLE    @SIZEOF_DOUBLE@
#cmakedefine SIZEOF_FLOAT     @SIZEOF_FLOAT@
#cmakedefine SIZEOF_INT       @SIZEOF_INT@
#cmakedefine SIZEOF_LONG_INT  @SIZEOF_LONG_INT@
#cmakedefine SIZEOF_LONG_LONG_INT @SIZEOF_LONG_LONG_INT@
#cmakedefine SIZEOF_SHORT_INT @SIZEOF_SHORT_INT@
#cmakedefine SIZEOF_VOID_P    @SIZEOF_VOID_P@

/* Standard C headers */
#cmakedefine HAVE_FCNTL_H 1
#cmakedefine HAVE_FLOAT_H 1
#cmakedefine HAVE_FENV_H 1
#cmakedefine HAVE_LIMITS_H 1
#cmakedefine HAVE_STDDEF_H 1
#cmakedefine HAVE_STDLIB_H 1
#cmakedefine HAVE_STRING_H 1
#cmakedefine HAVE_STDIO_H 1
#cmakedefine HAVE_ASSERT_H 1
#cmakedefine HAVE_SYS_TIME_H 1
#cmakedefine HAVE_SYS_TYPES_H 1
#cmakedefine HAVE_SYS_STAT_H 1
#cmakedefine HAVE_MEMORY_H 1
#cmakedefine HAVE_STRINGS_H 1
#cmakedefine HAVE_INTTYPES_H 1
#cmakedefine HAVE_STDINT_H 1
#cmakedefine HAVE_UNISTD_H 1

/* C++ features */
#cmakedefine HAVE_TR1_UNORDERED_MAP 1
#cmakedefine HAVE_TR1_UNORDERED_SET 1
#cmakedefine HAVE_TR1_UNORDERED_MAP_WITH_STD_HEADER 1
#cmakedefine HAVE_TR1_UNORDERED_SET_WITH_STD_HEADER 1
#cmakedefine HAVE_STD_LIMITS 1
#cmakedefine HAVE_NAMESPACES 1
#cmakedefine HAVE_SSTREAM 1

/* External libraries */
#cmakedefine HAVE_PETSC 1
#cmakedefine WITH_PETSCSCALAR_DOUBLE 1
#cmakedefine HAVE_CGNSLIB_H 1
#cmakedefine HAVE_CGNS 1
#cmakedefine HAVE_VTKCONFIGURE_H 1
#cmakedefine HAVE_VTK 1

#endif /* _CONFIG_H_CMAKE */
