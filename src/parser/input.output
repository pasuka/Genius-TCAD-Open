Terminale, die in Grammatik unbenutzt sind

    ENDFILE
    BLANK
    BAD_WORD
    MOD
    LOWEST
    ELSE
    UNARYHIGH
    LEFTSQUARE
    LEFTPAREN
    HIGHEST


Grammatik

    0 $accept: inputfile $end

    1 inputfile: TITLE STRING_VALUE
    2          | command
    3          | inputfile command

    4 command: statement LINEINFO
    5        | expr ';' LINEINFO
    6        | BOOL_TYPE BOOL_ID '=' bool_expr ';' LINEINFO
    7        | INT_TYPE INT_ID '=' int_expr ';' LINEINFO
    8        | REAL_TYPE REAL_ID '=' real_expr ';' LINEINFO
    9        | STRING_TYPE STRING_ID '=' string_expr ';' LINEINFO
   10        | COMMENT LINEINFO
   11        | LINEINFO

   12 statement: KEYWORD
   13          | KEYWORD parameters

   14 expr: %empty
   15     | BOOL_ID '=' bool_expr
   16     | INT_ID '=' int_expr
   17     | REAL_ID '=' real_expr
   18     | STRING_ID '=' string_expr

   19 bool_expr: BOOL_VALUE
   20          | BOOL_ID
   21          | bool_expr AND bool_expr
   22          | bool_expr OR bool_expr
   23          | bool_expr EQ bool_expr
   24          | bool_expr NE bool_expr
   25          | '(' bool_expr ')'
   26          | NOT bool_expr
   27          | real_expr LT real_expr
   28          | real_expr GT real_expr
   29          | real_expr LE real_expr
   30          | real_expr GE real_expr
   31          | real_expr EQ real_expr
   32          | real_expr NE real_expr

   33 int_expr: INT_VALUE
   34         | INT_ID
   35         | '(' int_expr ')'
   36         | int_expr PLUS int_expr
   37         | int_expr MINUS int_expr
   38         | int_expr ASTERISK int_expr
   39         | int_expr DIVIDE int_expr
   40         | MINUS int_expr
   41         | PLUS int_expr

   42 real_expr: REAL_VALUE
   43          | INT_VALUE
   44          | REAL_ID
   45          | INT_ID
   46          | '(' real_expr ')'
   47          | real_expr PLUS real_expr
   48          | real_expr MINUS real_expr
   49          | real_expr ASTERISK real_expr
   50          | real_expr DIVIDE real_expr
   51          | MINUS real_expr
   52          | PLUS real_expr

   53 string_expr: STRING_VALUE
   54            | STRING_ID
   55            | INT_ID
   56            | string_expr PLUS string_expr

   57 bool_exprs: bool_expr
   58           | bool_exprs ',' bool_expr

   59 real_exprs: real_expr
   60           | real_exprs ',' real_expr

   61 int_exprs: int_expr
   62          | int_exprs ',' int_expr

   63 string_exprs: string_expr
   64             | string_exprs ',' string_expr

   65 parameters: parameter
   66           | parameters parameter

   67 parameter: REAL_PARAMETER '=' real_expr
   68          | UD_REAL_PARAMETER '=' real_expr
   69          | REAL_PARAMETER '=' '[' real_exprs ']'
   70          | UD_REAL_PARAMETER '=' '[' real_exprs ']'
   71          | INT_PARAMETER '=' int_expr
   72          | UD_INT_PARAMETER '=' int_expr
   73          | INT_PARAMETER '=' '[' int_exprs ']'
   74          | UD_INT_PARAMETER '=' '[' int_exprs ']'
   75          | STRING_PARAMETER '=' string_expr
   76          | UD_STRING_PARAMETER '=' string_expr
   77          | STRING_PARAMETER '=' '[' string_exprs ']'
   78          | STRING_PARAMETER
   79          | UD_STRING_PARAMETER '=' '[' string_exprs ']'
   80          | BOOL_PARAMETER '=' bool_expr
   81          | UD_BOOL_PARAMETER '=' bool_expr
   82          | BOOL_PARAMETER '=' '[' bool_exprs ']'
   83          | UD_BOOL_PARAMETER '=' '[' bool_exprs ']'


